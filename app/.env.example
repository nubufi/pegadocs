# ── Core ────────────────────────────────────────────────────
# env: prod | staging | dev
ENV=prod

# Enable mock API to skip all external services (great for UI development)
ENABLE_MOCK_API=false

# Web scraping API key
SPIDER_WEB_API_KEY=

# ── Security ────────────────────────────────────────────────
# Generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=

# ── Auth Provider ───────────────────────────────────────────
# supabase or local
AUTH_PROVIDER=supabase

# --- Supabase (when AUTH_PROVIDER=supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Local Auth (when AUTH_PROVIDER=local) ---
# Postgres connection for user tables
DB_URL=postgresql+asyncpg://pegadocs:pegadocs@postgres:5432/pegadocs

# JWT secret for local auth tokens
LOCAL_AUTH_JWT_SECRET=

# ── Authentication ──────────────────────────────────────────
# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1

# Hardcoded API key for testing
TEST_API_KEY=

# ── Redis (Task Queue) ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Celery (Worker Queue) ───────────────────────────────────
# Broker and result backend (defaults use Redis above)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4

# ── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1

# Queue URL for Lambda embedding jobs
EMBEDDING_JOBS_SQS_URL=

# ── S3 Storage ──────────────────────────────────────────────
S3_DATA_SOURCE_BUCKET_NAME=
S3_EMBEDDING_BUCKET_NAME=
DEFAULT_VECTOR_BUCKET_NAME=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Site ────────────────────────────────────────────────────
SITE_URL=https://pegadocs.com

# ── Task Store ──────────────────────────────────────────────
# redis or dynamodb
TASK_STORE=redis

# DynamoDB table name (when TASK_STORE=dynamodb)
DDB_TABLE=tasks
TTL_SECONDS=86400

# ── Observability ───────────────────────────────────────────
SENTRY_DSN=

# ── Document Processing ──────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=20

# ── Table Name Overrides (optional) ──────────────────────────
# API_KEYS_TABLE_NAME=api_keys
# CHAT_HISTORY_TABLE_NAME=chats
# COLLECTIONS_TABLE_NAME=collections
# DATA_SOURCES_TABLE_NAME=data_sources
# DATABASE_TABLE_NAME=databases
# MODELS_TABLE_NAME=models
# PROMPT_TABLE_NAME=prompts
# JOB_STATUS_TABLE_NAME=job_status
# FILE_STATUS_TABLE_NAME=file_status
# NODES_TABLE_NAME=nodes_status
# LOCAL_USERS_TABLE_NAME=local_users
# LOCAL_REFRESH_TOKENS_TABLE_NAME=local_refresh_tokens
# LOCAL_PASSWORD_RESET_TOKENS_TABLE_NAME=local_password_reset_tokens
# LOCAL_API_KEYS_TABLE_NAME=local_api_keys
# LOCAL_METADATA_TABLE_NAME=local_metadata
